{
    "layer": "top",
    "position": "top",
    "margin-top": 8,
    "margin-left": 12,
    "margin-right": 12,
    "height": 36,
    "spacing": 0,

    "modules-left": ["hyprland/workspaces"],
    "modules-center": ["clock"],
    "modules-right": ["mpris","pulseaudio", "network", "tray", "custom/power"],

    "hyprland/workspaces": {
        "format": "{icon}",
        "format-icons": {
            "active": "●",
            "default": "○",
            "urgent": "◉"
        },
        "on-scroll-up": "hyprctl dispatch workspace e+1",
        "on-scroll-down": "hyprctl dispatch workspace e-1",
        "all-outputs": false
    },

    "clock": {
        "format": "{:%H:%M}",
        "format-alt": "{:%A, %d %B - %H:%M}",
        "tooltip-format": "{calendar}",
        "calendar": {
            "mode": "month",
            "weeks-pos": "left"
        }
    },

    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "󰝟 muted",
        "format-icons": {
            "default": ["󰕿", "󰖀", "󰕾"]
        },
        "on-click": "pavucontrol",
        "on-scroll-up": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 1%+",
        "on-scroll-down": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 1%-",
        "scroll-step": 1
        },

        "network": {
        "format-wifi": "󰤨 ",
        "format-ethernet": "󰤨 ",
        "format-disconnected": "󰤭 ",
        "tooltip-format": "vyevdnet — {ipaddr}\n↑ {bandwidthUpBits}  ↓ {bandwidthDownBits}",
        "interval": 5
    },

    "mpris": {
        "format": "{title}",
        "format-paused": "{title} (paused)",
        "player": "spotify",
        "max-length": 60,
        "on-click": "playerctl --player=spotify play-pause",
        "on-click-right": "playerctl --player=spotify next",
        "on-click-middle": "playerctl --player=spotify previous",
        "tooltip": false
    },

    "custom/power": {
        "format": "⏻",
        "on-click": "~/.config/rofi/scripts/powermenu.sh",
        "tooltip": false
    },

    "tray": {
        "spacing": 8,
        "icon-size": 18
    }
}
