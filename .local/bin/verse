#!/bin/bash

CACHE="$HOME/.cache/verse"
MAX_AGE=300

mkdir -p "$HOME/.cache"

fetch_and_format() {
    curl -s "https://bible-api.com/?random=verse" | python3 -c "
import sys, json, textwrap, shutil
try:
    d = json.load(sys.stdin)
    v = d['verses'][0]
    text = v['text'].strip()
    ref = f'{v[\"book_name\"]} {v[\"chapter\"]}:{v[\"verse\"]}'
    gold = '\033[38;2;230;212;123m'
    red = '\033[38;2;187;96;123m'
    reset = '\033[0m'
    width = shutil.get_terminal_size().columns - 4
    wrapped = textwrap.fill(text, width=width)
    print(f'  {gold}{wrapped}{reset}')
    print(f'  {red}— {ref}{reset}')
    print()
except: print('\033[38;2;230;212;123mfailed to fetch verse\033[0m')
"
}

if [ -f "$CACHE" ]; then
    cat "$CACHE"
    age=$(( $(date +%s) - $(stat -c %Y "$CACHE" 2>/dev/null || echo 0) ))
    if [ "$age" -gt "$MAX_AGE" ]; then
        (fetch_and_format > "$CACHE.tmp" && mv "$CACHE.tmp" "$CACHE") &>/dev/null &
    fi
    exit 0
fi

fetch_and_format | tee "$CACHE"
